{
  "compilerOptions": {
    "target": "ES2020",
    "module": "commonjs",
    "lib": ["ES2020"],
    "strict": true,
    "esModuleInterop": true,
    "resolveJsonModule": true,
    "outDir": "./dist",
    "rootDir": ".",
    "skipLibCheck": true
  },
  "include": [
    "tests/**/*.ts",
    "Auth/**/*.ts",
    "Account/**/*.ts",
    "Products/**/*.ts",
    "Search/**/*.ts",
    "Cart/**/*.ts",
    "Checkout/**/*.ts",
    "Wishlist/**/*.ts",
    "Navigation/**/*.ts",
    "StaticPages/**/*.ts",
    "HomePage/**/*.ts",
    "playwright.config.ts"
  ],
  "exclude": ["node_modules", "dist"]
}
